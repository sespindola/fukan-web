<h2 class="text-2xl font-bold text-white mb-6">Resend unlock instructions</h2>

<%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-4">
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-white/70 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg bg-white/5 border border-white/10 px-3 py-2 text-white placeholder-white/40 focus:border-cyan-500 focus:ring-cyan-500 focus:outline-none" %>
    </div>

    <div>
      <%= f.submit "Resend unlock instructions", class: "w-full rounded-lg bg-cyan-500 px-4 py-2 text-sm font-semibold text-white hover:bg-cyan-600 transition-colors duration-200 cursor-pointer" %>
    </div>
  </div>
<% end %>

<%= render "devise/shared/links" %>
