<h2 class="text-xl font-semibold text-white mb-2">Reset password</h2>
<p class="text-sm text-slate-400 mb-6">Enter your email and we'll send you instructions.</p>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-5">
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "name@company.com", class: "block w-full rounded-xl bg-white/5 border border-white/10 px-4 py-2.5 text-white shadow-sm ring-1 ring-inset ring-transparent placeholder:text-slate-500 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 focus:outline-none transition-all duration-200 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit "Send instructions", class: "flex w-full justify-center rounded-xl bg-cyan-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-cyan-900/20 hover:bg-cyan-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-600 transition-all duration-200 cursor-pointer active:scale-[0.98]" %>
    </div>
  </div>
<% end %>

<div class="mt-8 pt-6 border-t border-white/5">
  <p class="text-center text-sm text-slate-500">
    Remember your password? 
    <%= link_to "Log in", new_session_path(resource_name), class: "font-medium text-cyan-400 hover:text-cyan-300 transition-colors" %>
  </p>
</div>
